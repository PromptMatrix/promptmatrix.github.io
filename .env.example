# ── Database ──────────────────────────────────────────────────────
# For production (Vercel/Supabase): postgresql://...:6543/postgres
# For self-host (SQLite): sqlite:///./promptmatrix.db
DATABASE_URL=sqlite:///./promptmatrix.db

# ── Auth ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Encryption (SEPARATE from JWT secret — never rotate these together) ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-separate-encryption-key-here

# ── App ──────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://your-project.vercel.app
FRONTEND_URL=https://promptmatrix.github.io

# ── Email (Resend — free tier: 100 emails/day) ───────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@promptmatrix.io

# ── Cache (Upstash Redis — free tier: 10k commands/day) ──────────
# https://console.upstash.com → Create Database → REST API
# Leave blank to disable cache (DB reads on every request — fine at low scale)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxx

# ── Payments (Razorpay) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Cache TTLs ───────────────────────────────────────────────────
PROMPT_CACHE_TTL_SECONDS=30
API_KEY_CACHE_TTL_SECONDS=300

# ── Rate limiting ─────────────────────────────────────────────────
# Max requests per minute per API key on /pm/serve
# Requires Upstash Redis. Set to 0 to disable entirely.
SERVE_RATE_LIMIT_RPM=600
