# PromptMatrix — Local-First Configuration
# Copy this file to .env and set the values below.
# This is a STANDALONE local application. No cloud accounts required.

# ── Required ─────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
# The setup scripts (start.sh / start.bat) will generate this automatically.
JWT_SECRET_KEY=change-me-to-a-random-secret

# ── Optional (defaults work out of the box) ──────────────────────────────
DATABASE_URL=sqlite:///./promptmatrix.db
APP_ENV=development
APP_URL=http://localhost:8000
ENCRYPTION_KEY=
DEBUG=false

# ── Auth Behaviour ───────────────────────────────────────────────────────
# APP_ENV=development (default):
#   - No login screen. PromptMatrix auto-creates a "Local Admin" user on
#     first run and logs in automatically. Perfect for local solo use.
#
# APP_ENV=production:
#   - Login screen is shown. Users must register/login with email + password.
#   - Use this when deploying for a team with a shared PostgreSQL database.
#   - Swap DATABASE_URL to your PostgreSQL connection string (uncomment
#     psycopg2-binary in requirements.txt).
#
# DATABASE_URL=postgresql://user:password@host:5432/promptmatrix

# ── Performance ──────────────────────────────────────────────────────────
PROMPT_CACHE_TTL_SECONDS=30
API_KEY_CACHE_TTL_SECONDS=300
SERVE_RATE_LIMIT_RPM=600
