# ☁️ PromptMatrix - Private Cloud Runtime Configuration
# This file is for the managed backend version (Vercel + Supabase + Upstash)
# DO NOT COMMIT SECRETS TO PUBLIC GITHUB

APP_ENV=cloud
APP_URL=https://promptmatrixx.vercel.app
FRONTEND_URL=https://promptmatrixx.vercel.app/dashboard

# 🗄 Managed Persistence (Supabase / Postgres)
# Copy the connection string from Supabase Settings -> Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# ⚡ Performance (Upstash Redis)
# For managed rate limiting and caching at the edge
UPSTASH_REDIS_REST_URL=https://[YOUR_INSTANCE].upstash.io
UPSTASH_REDIS_REST_TOKEN=[YOUR_SECRET_TOKEN]

# 📧 Transactional Email (Resend)
RESEND_API_KEY=re_[YOUR_SECRET_KEY]
FROM_EMAIL=governance@yourdomain.com

# 🔐 Professional Security
# Generate a secure 32-char key for encryption
JWT_SECRET_KEY=[SECURE_LONG_RANDOM_STRING]
ENCRYPTION_KEY=[ANOTHER_SECURE_LONG_RANDOM_STRING]

# 🚀 Performance Tuning
PROMPT_CACHE_TTL_SECONDS=30
SERVE_RATE_LIMIT_RPM=6000 # Higher limit for cloud scale
